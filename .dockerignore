# Secrets — env files NEVER ship in the image
.env
.env.*
.env.bak.*
!.env.production.example

# Local dev artifacts
.git
.github
.idea
.vscode
.phpunit.cache
node_modules
storage/app/private/projects
storage/app/private/deals
storage/app/public/*.xlsx
storage/logs/*.log
# NOTE: do NOT exclude storage/framework/{cache/data,sessions,views} themselves
# — Laravel needs those directories to exist at boot ("Please provide a valid
# cache path"). The .gitignore stubs inside them are how the empty dirs survive
# git; excluding the whole paths here would strip those stubs too.
# Only exclude actual cached/generated content under bootstrap/cache:
bootstrap/cache/*.php
public/hot
public/storage

# Tests / docs we don't need at runtime
tests
phpunit.xml
*.md
openspec

# OS junk
.DS_Store
Thumbs.db
~$*
