# Secrets — env files NEVER ship in the image
.env
.env.*
.env.bak.*
!.env.production.example

# Local dev artifacts
.git
.github
.idea
.vscode
.phpunit.cache
node_modules
storage/app/private/projects
storage/app/private/deals
storage/app/public/*.xlsx
storage/logs/*.log
storage/framework/cache/data
storage/framework/sessions
storage/framework/views
bootstrap/cache/*.php
public/hot
public/storage

# Tests / docs we don't need at runtime
tests
phpunit.xml
*.md
openspec

# OS junk
.DS_Store
Thumbs.db
~$*
