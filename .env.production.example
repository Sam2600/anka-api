# anka-api production env template.
# Copy to `.env` on the EC2 host, fill in every TODO, then `docker compose up -d`.
# NEVER commit .env. The .dockerignore already excludes it from the image build.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=ANKA
APP_ENV=production
APP_KEY=                                  # TODO: generate via `docker compose run --rm app php artisan key:generate --show`
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://anka-api.kaunghtetsan.com

# ── Frontend / CORS ──────────────────────────────────────────────────────────
# Drives config/cors.php — the ONLY origin allowed to call this API.
FRONTEND_URL=https://app.kaunghtetsan.com   # TODO: replace with your frontend's prod URL

# ── Logging ──────────────────────────────────────────────────────────────────
# `stderr` is what `docker logs` picks up; keep here for prod.
LOG_CHANNEL=stderr
LOG_LEVEL=info

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Use the *pooler* endpoint for production traffic (port 6543). Pooler URL
# format: aws-0-<region>.pooler.supabase.com. Find both in Supabase dashboard
# → Project Settings → Database → Connection pooling.
DB_CONNECTION=pgsql
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com  # TODO: your pooler host
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.YOUR_PROJECT_REF              # TODO: postgres.<project ref>
DB_PASSWORD=                                       # TODO: paste the Supabase DB password
DB_SSLMODE=require

# ── Sessions / queue / cache ─────────────────────────────────────────────────
# All on the DB to start with. Add Redis later if you outgrow this.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.kaunghtetsan.com   # share cookies across api + frontend subdomains
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ── Sanctum ──────────────────────────────────────────────────────────────────
# API tokens don't need stateful_domains, but if the frontend ever uses
# cookie auth, list the frontend host here.
SANCTUM_STATEFUL_DOMAINS=app.kaunghtetsan.com

# ── Mail (Mailgun via Symfony) ───────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=                                    # TODO
MAIL_PASSWORD=                                    # TODO
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@kaunghtetsan.com
MAIL_FROM_NAME="ANKA"

# ── Anthropic (or Anthropic-compatible proxy) ────────────────────────────────
# Two valid setups — pick ONE:
#
#   A) Direct to Anthropic
#      ANTHROPIC_BASE_URL=https://api.anthropic.com
#      ANTHROPIC_API_KEY=sk-ant-api03-...   (real CF console.anthropic.com key, ~108 chars)
#
#   B) Through a compatible proxy (e.g. internal gateway, reseller)
#      ANTHROPIC_BASE_URL=https://api.vibecode-claude.online   (or whatever proxy you use)
#      ANTHROPIC_API_KEY=<key the proxy issues>                (proxy keys can be short / any prefix)
#
# Critical: the key format must match the BASE_URL it's paired with. A proxy
# key (sk-9b...) sent to api.anthropic.com → 401. A real Anthropic key sent
# to the proxy may or may not work depending on the proxy.
ANTHROPIC_API_KEY=                                 # TODO
ANTHROPIC_BASE_URL=                                # TODO: pick A or B above
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_SCHEDULE_RETRIES=2
ANTHROPIC_SCHEDULE_MAX_TOKENS=16384
ANTHROPIC_SCHEDULE_MODEL=claude-3-5-sonnet-latest

# ── Cloudflare trusted proxies ───────────────────────────────────────────────
# Laravel 11+ honors `TRUSTED_PROXIES=*` to trust any forwarded headers.
# Safe here because only Cloudflare can reach nginx (security group below).
TRUSTED_PROXIES=*
