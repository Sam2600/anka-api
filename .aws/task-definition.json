{
  "family": "anka-task-def",
  "executionRoleArn": "arn:aws:iam::585768173043:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "3072",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "volumes": [],
  "placementConstraints": [],
  "containerDefinitions": [
    {
      "name": "anka",
      "image": "585768173043.dkr.ecr.ap-southeast-1.amazonaws.com/anka:placeholder",
      "cpu": 0,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "anka-8080-tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [],
      "environmentFiles": [
        {
          "value": "arn:aws:s3:::anka-bucket/.env",
          "type": "s3"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "systemControls": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/anka-task-def",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      }
    }
  ]
}
